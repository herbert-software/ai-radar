# ai-radar 环境变量示例
# 复制为 .env 并填入真实值；缺关键变量时应用启动即报错（见 src/config/env.ts）。

# --- 基础设施 ---
# PostgreSQL（pgvector 镜像）连接串，对应 docker-compose 的 postgres 服务
DATABASE_URL=postgres://ai_radar:ai_radar@localhost:5432/ai_radar

# Redis 连接串（供 BullMQ / 健康检查使用）
REDIS_URL=redis://localhost:6379

# --- LLM provider ---
# provider 经 Vercel AI SDK 抽象，走 OpenAI 兼容接口（默认 OpenRouter）。
# LLM provider API key（OpenRouter 的 key 形如 sk-or-...）
LLM_API_KEY=sk-your-key-here

# 模型名：OpenRouter 用 "<vendor>/<model>" 形式，如 openai/gpt-4o-mini
# 或 anthropic/claude-3.5-sonnet。
LLM_MODEL=openai/gpt-4o-mini

# OpenAI 兼容端点。默认 OpenRouter；换其他兼容 provider 时改这里。
LLM_BASE_URL=https://openrouter.ai/api/v1

# 单次 LLM 调用（generateObject）超时毫秒数，防一条挂起的响应卡死评分/摘要阶段（LLM 比 fetch 慢，默认 60s）
LLM_TIMEOUT_MS=60000

# --- Telegram 推送（必填）---
# bot token：@BotFather 创建 bot 后获取
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# 目标 chat id：推送日报的目标会话（个人/群/频道）id
TELEGRAM_CHAT_ID=123456789

# --- 飞书自定义机器人推送（可选）---
# 飞书是可选通道：两者均留空 → 飞书 disabled，纯 Telegram 部署照常启动（向后兼容）。
# 仅配其一（不完整）→ 启动即报错；两者都填 → 启用飞书通道，日报并发推送到 Telegram + 飞书。
# 获取：飞书群 → 设置 → 群机器人 → 添加自定义机器人 → 复制 Webhook 地址；
# 安全设置勾选「签名校验」后复制密钥（FEISHU_SIGN_SECRET）。
FEISHU_WEBHOOK_URL=
FEISHU_SIGN_SECRET=

# --- 推送时区 ---
# push_date 与候选窗口「今天」同源此时区，钉死防跨 UTC 零点重复推送
PUSH_TIMEZONE=Asia/Shanghai

# --- Top N 与组合分权重 ---
# 每日推送的事件条数上限
TOP_N=8
# 组合分 rank_score = w_imp*importance + w_dev*developer_relevance
#                     + w_nov*novelty − w_hype*hype_risk（hype_risk 为减项）
RANK_WEIGHT_IMPORTANCE=0.45
RANK_WEIGHT_DEVELOPER_RELEVANCE=0.25
RANK_WEIGHT_NOVELTY=0.2
RANK_WEIGHT_HYPE_RISK=0.1
# importance 下限闸：低于此值的事件不进 Top N（宁缺毋滥）
IMPORTANCE_FLOOR=60

# --- 降级率熔断 ---
# 任一阶段（Value Judge / 摘要）分母>0 且降级率严格 > 此值 → 中止并告警，不推残缺日报
DEGRADE_ABORT_RATIO=0.5

# --- 候选窗口 ---
# 候选时效窗口天数（近 N 天）。语义已变更：时效闸键于 published_at（发布近 N 天），
# 非 first_seen_at（抓取近 N 天）——变量名保留以保配置兼容。NULL published_at 经 AI 推断
# 回填、仍 NULL 则排除。
FIRST_SEEN_WINDOW_DAYS=3

# --- 发布时间 AI 推断成本闸 ---
# 单轮回填（published-at-inference）最多对多少个 NULL published_at 事件调 LLM 推断。
# 独立成本闸，硬封单轮 LLM 调用量（Top N / 告警单次上限限不住回填作用域）；超出者下轮补填。
PUBLISHED_AT_INFERENCE_MAX_PER_RUN=20

# --- BullMQ 每日定时触发 ---
# cron 表达式（BullMQ repeat.pattern）触发 daily-digest 任务，默认每日 08:03。
# 分钟字段刻意避开整点/半点（∉ {0,30}）：飞书自定义机器人限流（11232），整点/半点是
# 多服务集中推送高压时刻，08:03 错峰降低限流概率。
DAILY_DIGEST_CRON=3 8 * * *
# cron 时区，默认与 push_date 同源 Asia/Shanghai，防触发时区与 push_date 口径漂移。
DAILY_DIGEST_CRON_TZ=Asia/Shanghai
# 整 job 重试次数（BullMQ 作整 job 重试外壳，不拆阶段队列）。
DAILY_DIGEST_JOB_ATTEMPTS=3

# --- Collector 源清单 ---
# 带 vendor 标记的 RSS feed 配置：逗号分隔多个 url|vendor 条目（vendor 可空）。
# 每个条目须恰好含一个 | 分隔符；旧裸 URL 格式（无 |）启动即报错。
# vendor 段为空（url| 尾随空 vendor）表示无厂商标记（metadata.vendor=null），适合自加的普通博客。
# T1 大厂官方 feed（已实测有效、信号最高、零鉴权）。扩源第一梯队追加 9 条一手厂商/工具源
# （URL 必须含 https:// scheme；research.google 与 blog.google 同 vendor=google，feed_url 区分；
#  microsoft 与既有 Microsoft AI 同 vendor，feed_url 区分；Perplexity changelog 月级粗粒度）：
RSS_FEEDS=https://openai.com/news/rss.xml|openai,https://deepmind.google/blog/rss.xml|deepmind,https://huggingface.co/blog/feed.xml|huggingface,https://mistral.ai/rss.xml|mistral,https://news.microsoft.com/source/topics/ai/feed/|microsoft,https://github.blog/feed/|github,https://github.blog/changelog/feed/|github,https://lobste.rs/rss|lobsters,https://www.together.ai/blog/rss.xml|together,https://developer.nvidia.com/blog/feed/|nvidia,https://aws.amazon.com/blogs/machine-learning/feed/|aws,https://research.google/blog/rss/|google,https://blog.google/technology/ai/rss/|google,https://www.microsoft.com/en-us/research/feed/|microsoft,https://stability.ai/news-updates?format=rss|stability,https://feed.alternativeto.net/news/all|alternativeto,https://docs.perplexity.ai/docs/resources/changelog/rss.xml|perplexity
# GitHub API token（提升速率上限）；留空则匿名调用，受更严限流
GITHUB_TOKEN=
# 单次源网络调用（fetch / RSS parseURL）超时毫秒数，防实网挂起无限期卡死整个采集
COLLECTOR_FETCH_TIMEOUT_MS=15000

# --- Product Hunt 产品发现（必填）---
# Developer Token（只读）：在 https://www.producthunt.com/v2/oauth/applications 创建应用后生成。
# 缺失则产品发现采集启动即报错（不匿名静默继续）。用于 GraphQL 拉当日上榜产品先落 raw_items。
PRODUCT_HUNT_TOKEN=your-product-hunt-developer-token

# --- Show HN 产品发现（HN Algolia，无鉴权）---
# 众投质量闸：仅采 points >= 此值的 Show HN。points 为 HN 群体投票的**确定性闸、非语义判断**
# （与 GitHub「按 star 倒序」同类；区别：绝对阈值，某轮可能 0 条达标→返回空，属预期不告警）。默认 10。
SHOW_HN_MIN_POINTS=10
# 单轮采集上限（Algolia hitsPerPage，本期不翻页）。默认 30。
# 时间窗（借 FIRST_SEEN_WINDOW_DAYS 天作 created_at_i 下界）**仅采集期控量**——
# 产品选品按 ai_products.last_seen_at、不经 published_at 时效窗。
SHOW_HN_MAX_PER_RUN=30

# --- Hugging Face Papers（每日精选论文，官方 JSON API daily_papers，无鉴权）---
# 论文仅沉淀（rawType='paper'、collapsed=true，与 arXiv 同口径，不进事件/日报/推送，论文板块留 P3）。
# 单轮采集上限（daily_papers ~50 条/日）。默认 50。
HF_PAPERS_MAX_PER_RUN=50

# --- sitemap 增量采集（无原生 RSS、但有 sitemap.xml + 文章页 og: 标签的一手 lab 新闻）---
# 配置驱动：逗号分隔多个 `sitemapUrl|pathPrefix|vendor` 条目（恰好 3 段）。
# 段数≠3 / 任一段空 / pathPrefix 不以 / 开头 → 启动即报错。窗口复用 FIRST_SEEN_WINDOW_DAYS。
# 首期 Anthropic News（rawType='news' 进日报；published_at 留空走 published-at-inference）。
SITEMAP_SOURCES=https://www.anthropic.com/sitemap.xml|/news/|anthropic

# --- 实时重大发布告警（realtime-alerts，独立高频调度，与日报并列）---
# 「重大发布」实时告警阈值：评分**后**判 importance_score IS NOT NULL AND >= 此值才告警。
# 默认 85，严于日报候选（importance>=75）与 Top N 下限闸（>=60）——实时门槛更高防告警刷屏。
# 判定纯程序阈值，禁止 LLM 决定是否告警。
ALERT_IMPORTANCE_THRESHOLD=85
# 实时告警高频轮询 cron（BullMQ repeat.pattern）+ 时区。默认每 20 分钟（保守，靠真实数据调）。
# 高频链路只采实时新闻源 {rss,hacker_news,github}（不碰 arXiv 非实时 / PH 配额受限）；
# 全源 0/空轮是常态、不套用日报「全源 0」系统级告警（防刷屏）。
ALERT_SCAN_CRON=*/20 * * * *
ALERT_SCAN_CRON_TZ=Asia/Shanghai
# 整 job 重试次数（BullMQ 整 job 重试外壳）
ALERT_SCAN_JOB_ATTEMPTS=3
# 告警单例锁 alert:{channel}:{event_id} TTL（毫秒）：job 级短时持有，覆盖「单事件渲染+单通道送达」
# 最坏时长；崩溃经 TTL 自动释放（锁键不含时间，无 TTL 会永久死锁该事件告警，故释放语义不可省）。
ALERT_LOCK_TTL_MS=60000

# --- 周报 weekly-report 调度开关 ---
# 默认 false（暂禁用，待打磨后改 true 启用）。关闭时 worker 不注册/启动 weekly-report 调度链；
# 周报实现与测试保留、随时可开。其余三链（daily-digest / product-digest / alert-scan）不受影响。
WEEKLY_REPORT_ENABLED=false

# --- 并发评分原子 claim 回收阈值 T（日报链 + 告警高频链共用，防双评分）---
# 日报链与告警高频链可能并发对同一未评分事件评分；送 LLM 前原子 claim（写 judge_claimed_at），
# 仅 claim 成功者评分。被 claim 的事件停在「score NULL + 已 claim」的总时长 = L(LLM_TIMEOUT_MS)
# + W(JUDGE_WRITE_BUDGET_MS 写分提交延迟上界)。回收阈值 T 必须**严格 > L + W**——否则正在合法
# 评分/写分的事件会被另一链路误回收双写。启动期跨字段校验 T > LLM_TIMEOUT_MS + JUDGE_WRITE_BUDGET_MS。
# 默认 180000（> 60000 + 60000）。
JUDGE_CLAIM_RECLAIM_MS=180000
JUDGE_WRITE_BUDGET_MS=60000

# --- P3 语义去重 + 知识库 embedding（add-semantic-dedup-and-store-hardening）---
# embedding 模型名（经 Vercel AI SDK embed/embedMany 调用）。默认 text-embedding-3-small（1536 维、多语种、便宜）。
# 注意：向量列维度在迁移中钉死 1536，换不同维度模型属新的 forward-only 迁移、非热切——改本值须配套迁移。
EMBEDDING_MODEL=text-embedding-3-small
# 构造 embedding 文本时代表 raw_item content 摘录的截断字符数（防超长文本撑爆 token/调用）。默认 2000。
EMBEDDING_TEXT_MAX_CHARS=2000
# 候选窗口 bootstrap 单轮 backlog 上限：单轮日报最多为多少条 embedding 缺失的窗内事件补嵌（余量后续轮次续嵌）。
# 防 P3 首部署一次性嵌满 14 天 backlog 撑爆调用 / 拖住日报锁。默认 500。
EMBEDDING_BOOTSTRAP_MAX_PER_RUN=500
# 语义去重高相似度自动合并阈值：cosine_sim > 此值 → 直接判同事件合并（跳过 LLM）。默认 0.88（QA §9.2 起点，非实测调优）。
SEMANTIC_DEDUP_HIGH=0.88
# 语义去重 LLM 二次判断下界阈值：LLM < sim <= HIGH → 交 LLM；sim <= 此值 → 不合并。默认 0.82。
# 不变量：必须 SEMANTIC_DEDUP_LLM < SEMANTIC_DEDUP_HIGH（启动期跨字段校验），否则灰区为空、分流失效。
SEMANTIC_DEDUP_LLM=0.82
# 语义去重候选时间窗（天数）：仅在 first_seen_at >= now()-此值 的窗内检索 KNN 候选 + 补嵌。默认 14（跨天去重需比历史存活者）。
SEMANTIC_WINDOW_DAYS=14
# 语义去重总开关（on/off）：'on' 启用语义合并阶段；'off' 跳过、退回硬去重态。默认 on。仅日报链调用语义层。
SEMANTIC_DEDUP_ENABLED=on
