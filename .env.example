# ai-radar 环境变量示例
# 复制为 .env 并填入真实值；缺关键变量时应用启动即报错（见 src/config/env.ts）。

# --- 基础设施 ---
# PostgreSQL（pgvector 镜像）连接串，对应 docker-compose 的 postgres 服务
DATABASE_URL=postgres://ai_radar:ai_radar@localhost:5432/ai_radar

# Redis 连接串（供 BullMQ / 健康检查使用）
REDIS_URL=redis://localhost:6379

# --- LLM provider ---
# provider 经 Vercel AI SDK 抽象，走 OpenAI 兼容接口（默认 OpenRouter）。
# LLM provider API key（OpenRouter 的 key 形如 sk-or-...）
LLM_API_KEY=sk-your-key-here

# 模型名：OpenRouter 用 "<vendor>/<model>" 形式，如 openai/gpt-4o-mini
# 或 anthropic/claude-3.5-sonnet。
LLM_MODEL=openai/gpt-4o-mini

# OpenAI 兼容端点。默认 OpenRouter；换其他兼容 provider 时改这里。
LLM_BASE_URL=https://openrouter.ai/api/v1

# 单次 LLM 调用（generateObject）超时毫秒数，防一条挂起的响应卡死评分/摘要阶段（LLM 比 fetch 慢，默认 60s）
LLM_TIMEOUT_MS=60000

# --- Telegram 推送（必填）---
# bot token：@BotFather 创建 bot 后获取
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# 目标 chat id：推送日报的目标会话（个人/群/频道）id
TELEGRAM_CHAT_ID=123456789

# --- 推送时区 ---
# push_date 与候选窗口「今天」同源此时区，钉死防跨 UTC 零点重复推送
PUSH_TIMEZONE=Asia/Shanghai

# --- Top N 与组合分权重 ---
# 每日推送的事件条数上限
TOP_N=8
# 组合分 rank_score = w_imp*importance + w_dev*developer_relevance
#                     + w_nov*novelty − w_hype*hype_risk（hype_risk 为减项）
RANK_WEIGHT_IMPORTANCE=0.45
RANK_WEIGHT_DEVELOPER_RELEVANCE=0.25
RANK_WEIGHT_NOVELTY=0.2
RANK_WEIGHT_HYPE_RISK=0.1
# importance 下限闸：低于此值的事件不进 Top N（宁缺毋滥）
IMPORTANCE_FLOOR=60

# --- 降级率熔断 ---
# 任一阶段（Value Judge / 摘要）分母>0 且降级率严格 > 此值 → 中止并告警，不推残缺日报
DEGRADE_ABORT_RATIO=0.5

# --- 候选窗口 ---
# first_seen_at 在近 N 天内的事件才进候选
FIRST_SEEN_WINDOW_DAYS=3

# --- BullMQ 每日定时触发 ---
# cron 表达式（BullMQ repeat.pattern）触发 daily-digest 任务，默认每日 08:00。
DAILY_DIGEST_CRON=0 8 * * *
# cron 时区，默认与 push_date 同源 Asia/Shanghai，防触发时区与 push_date 口径漂移。
DAILY_DIGEST_CRON_TZ=Asia/Shanghai
# 整 job 重试次数（BullMQ 作整 job 重试外壳，不拆阶段队列）。
DAILY_DIGEST_JOB_ATTEMPTS=3

# --- Collector 源清单 ---
# RSS feed URL 列表，逗号分隔；留空则不采 RSS
RSS_FEEDS=
# GitHub API token（提升速率上限）；留空则匿名调用，受更严限流
GITHUB_TOKEN=
# 单次源网络调用（fetch / RSS parseURL）超时毫秒数，防实网挂起无限期卡死整个采集
COLLECTOR_FETCH_TIMEOUT_MS=15000
